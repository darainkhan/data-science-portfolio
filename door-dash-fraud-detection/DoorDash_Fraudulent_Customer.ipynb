    "# Get the test set with order amounts\n",
    "X_test_with_amounts = df_users.loc[X_test.index]\n",
    "\n",
    "# Fraud cases correctly caught (true positives)\n",
    "tp_mask = (y_pred == 1) & (y_test == 1)\n",
    "\n",
    "# Fraud cases missed (false negatives)\n",
    "fn_mask = (y_pred == 0) & (y_test == 1)\n",
    "\n",
    "fraud_mitigated = X_test_with_amounts.loc[tp_mask, 'latest_order_amount_usd'].sum()\n",
    "fraud_missed = X_test_with_amounts.loc[fn_mask, 'latest_order_amount_usd'].sum()\n",
    "total_fraud = X_test_with_amounts.loc[y_test == 1, 'latest_order_amount_usd'].sum()\n",
    "\n",
    "print(f\"Total fraud value in test set:  ${total_fraud:,.2f}\")\n",
    "print(f\"Fraud mitigated (caught):       ${fraud_mitigated:,.2f} ({fraud_mitigated/total_fraud*100:.1f}%)\")\n",
    "print(f\"Fraud missed (slipped through): ${fraud_missed:,.2f} ({fraud_missed/total_fraud*100:.1f}%)\")\n"
